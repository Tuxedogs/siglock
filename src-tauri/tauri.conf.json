{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SigLock",
  "version": "0.1.0-beta.2",
  "identifier": "com.siglock.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "SigLock",
        "width": 980,
        "height": 720,
        "minWidth": 680,
        "minHeight": 520,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": false,
        "transparent": false,
        "center": true
      },
      {
        "label": "overlay",
        "title": "SigLock Overlay",
        "url": "/overlay",
        "width": 340,
        "height": 240,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "focusable": false,
        "visible": true,
        "center": false,
        "x": 80,
        "y": 120,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis"
    ],
    "publisher": "SigLock",
    "resources": {
      "resources/tesseract/": "tesseract/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "English"
        ]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQxM0QwMzg3MUQ3QTk4RkYKUldUL21Ib2Rod005MFhib2pDdE1pRnRBMVVPT3E4WmJweVpHOXozUThyNS96cVUzSDFUZGtYUEcK",
      "endpoints": [
        "https://github.com/Tuxedogs/siglock/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
