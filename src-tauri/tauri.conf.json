{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SigLock",
  "version": "0.1.0",
  "identifier": "com.siglock.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "SigLock",
        "width": 980,
        "height": 720,
        "minWidth": 680,
        "minHeight": 520,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": false,
        "transparent": false,
        "center": true
      },
      {
        "label": "overlay",
        "title": "SigLock Overlay",
        "url": "/overlay",
        "width": 380,
        "height": 190,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false,
        "visible": true,
        "center": false,
        "x": 24,
        "y": 24
      },
      {
        "label": "region-picker",
        "title": "Select Scan Region - SigLock",
        "width": 1920,
        "height": 1080,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "publisher": "SigLock",
    "resources": {
      "resources/tesseract/": "tesseract/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "English"
        ]
      }
    }
  }
}
