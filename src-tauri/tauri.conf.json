{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SigLock",
  "version": "0.1.0",
  "identifier": "com.siglock.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "SigLock",
        "width": 420,
        "height": 560,
        "minWidth": 360,
        "minHeight": 420,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": false,
        "transparent": false,
        "center": true
      },
      {
        "label": "region-picker",
        "title": "Select Scan Region - SigLock",
        "width": 1920,
        "height": 1080,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
